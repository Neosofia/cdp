# Copy to ui/.env for local Vite dev (docker-compose.dev.yml loads ui/.env).
# Defaults in App.tsx match these ports when vars are unset.

CI=true
VITE_AUTH_BASE_URL=http://localhost:8014
VITE_AUTH_API_URL=http://localhost:8014
VITE_CAPABILITIES_API_URL=http://localhost:8019
VITE_USER_API_URL=http://localhost:8018
VITE_CHAT_API_URL=http://localhost:8001
VITE_CARE_EPISODE_API_URL=http://localhost:8015
VITE_TEMPLATE_API_URL=http://localhost:8900
# Optional: demo workspace bootstrap (defaults to DEMO-123 / Alice Hartley UUID in bootstrapDemoWorkspace.ts)
# VITE_DEMO_TEMPLATE_DISPLAY_CODE=DEMO-123
# VITE_DEMO_TEMPLATE_PATIENT_UUID=00000000-0000-7000-8000-000000002847
