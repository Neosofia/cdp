{
  "name": "ui",
  "private": true,
  "version": "2026.06.29",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "npm run preview",
    "test:e2e": "playwright test --project=desktop-chromium",
    "test:e2e:rwd": "playwright test --project=mobile-chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:staging": "playwright test e2e/care-episode-lifecycle.spec.ts e2e/visual-walkthrough.spec.ts",
    "test:e2e:headed": "playwright test --project=desktop-chromium --headed",
    "test:e2e:install": "playwright install chromium",
    "walkthrough:visual": "playwright test e2e/visual-walkthrough.spec.ts",
    "walkthrough:visual:mobile": "playwright test e2e/visual-walkthrough.spec.ts --project=mobile-chromium",
    "walkthrough:visual:desktop": "playwright test e2e/visual-walkthrough.spec.ts --project=desktop-chromium",
    "generate:api": "openapi-typescript ../../user/openapi.json -o src/shared/api/generated/user.schema.ts && openapi-typescript ../../care-episode/openapi.json -o src/shared/api/generated/care-episode.schema.ts && openapi-typescript ../../chat/openapi.json -o src/shared/api/generated/chat.schema.ts && openapi-typescript ../../authentication/openapi.json -o src/shared/api/generated/authentication.schema.ts && openapi-typescript ../../capabilities/openapi.json -o src/shared/api/generated/capabilities.schema.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-web": "^0.62.0",
    "@opentelemetry/context-zone-peer-dep": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/instrumentation": "^0.217.0",
    "@opentelemetry/instrumentation-fetch": "^0.217.0",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-form": "^1.31.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.14.0",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "openapi-typescript": "^7.13.0",
    "serve": "^14.2.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
