# Chat service — copy to .chat.env for local docker-compose.
SERVICE_NAME=chat
ENV=development
PORT=8001
JWT_AUDIENCE=authentication,chat
JWT_JWKS_URI=http://authentication:8014/.well-known/jwks.json
JWT_CLAIM_NAMESPACE=neosofia
FRONTEND_URL=http://localhost:5173
TRUSTED_PROXY_HOPS=0
AUTHORIZATION_POLICIES_DIR=policies
MIGRATION_DATABASE_URL=postgresql+psycopg://chat_template:change-me@chat-postgres:5432/cdp_chat
APP_DATABASE_URL=postgresql+psycopg://app:change-me@chat-postgres:5432/cdp_chat

# Care assistant inference. Set INFERENCE_API_KEY in local .chat.env (never commit the key).
INFERENCE_COMPLETIONS_URL=https://api.groq.com/openai/v1/chat/completions
INFERENCE_API_KEY=
INFERENCE_MODEL=openai/gpt-oss-120b
