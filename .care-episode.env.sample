# Care episode service — copy to .care-episode.env for local docker-compose.
SERVICE_NAME=care-episode
ENV=development
PORT=8015
JWT_AUDIENCE=authentication,care-episode
JWT_JWKS_URI=http://authentication:8014/.well-known/jwks.json
JWT_CLAIM_NAMESPACE=neosofia
FRONTEND_URL=http://localhost:5173
TRUSTED_PROXY_HOPS=0
AUTHORIZATION_POLICIES_DIR=policies
MIGRATION_DATABASE_URL=postgresql+psycopg://care_episode_template:change-me@care-episode-postgres:5432/cdp_care_episode
APP_DATABASE_URL=postgresql+psycopg://app:change-me@care-episode-postgres:5432/cdp_care_episode
# Chat base URL is resolved from the authentication service registry (slug: chat).
# From scripts/seed_services.py (care-episode client_credentials secret)
CARE_EPISODE_CLIENT_SECRET=change-me
# Demo template patient (DEMO-123); Cedar principal attribute demoTemplatePatientUuid.
DEMO_TEMPLATE_PATIENT_UUID=00000000-0000-7000-8000-000000002847
