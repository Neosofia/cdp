# Notification service — copy to .notification.env for local docker-compose.
RESEND_API_KEY=re_your_key_here
NOTIFICATION_FROM=noreply@neosofia.tech
NOTIFICATION_TO=inquiry@neosofia.tech
# CDP operator dashboard (5173) and corporate dev (4173) probe GET /health cross-origin.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://neosofia.tech
PORT=8005
ENV=development
