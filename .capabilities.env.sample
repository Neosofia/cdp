# Cedar policies — runtime path inside the container (default: /app/policies).
# Local dev: volume-mount cdp/policies/ (see docker-compose.dev.yml).
# Production: baked in via POLICY_IMAGE at capabilities build time (cdp-ui-policies image).
CAPABILITIES_POLICIES_DIR=policies

# S2S Authentication
AUTH_CLIENT_ID=capabilities
AUTH_CLIENT_SECRET=YOUR_SECRET
