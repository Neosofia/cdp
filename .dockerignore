# Environment files - never include in Docker build context
*.env
.*.env

# Version control
.git
.gitignore
.gitattributes

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.so

# Testing
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
*.o
*.a
*.so
.libs/

# Node (if any frontend)
node_modules/
npm-debug.log
yarn-error.log

# Documentation
docs/_build/

# Structurizr (generated viewer content is rebuilt in the image; see architecture/Dockerfile)
architecture/structurizr/content/*
!architecture/structurizr/content/.gitkeep
!architecture/structurizr/content/.gitignore
architecture/structurizr/.structurizr/
**/*-thumbnail.png
**/thumbnail.png

# OS
Thumbs.db

# Misc
.dockerignore
Dockerfile*
docker-compose*.yml
README.md
LICENSE

# Required by architecture/Dockerfile (Structurizr doc bake)
!README.md
!specs/
