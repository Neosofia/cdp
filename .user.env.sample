# User service — copy to .user.env for local docker-compose.
SERVICE_NAME=user
ENV=development
PORT=8018
JWT_AUDIENCE=authentication,user
JWT_JWKS_URI=http://authentication:8014/.well-known/jwks.json
JWT_CLAIM_NAMESPACE=neosofia
FRONTEND_URL=http://localhost:5173
TRUSTED_PROXY_HOPS=0
AUTHORIZATION_POLICIES_DIR=policies
ROLE_CATALOG_OVERLAY=/app/policies/role-catalog.json
MIGRATION_DATABASE_URL=postgresql+psycopg://user_template:change-me@user-postgres:5432/cdp_user
APP_DATABASE_URL=postgresql+psycopg://app:change-me@user-postgres:5432/cdp_user
